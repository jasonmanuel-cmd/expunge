# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Anthropic (Claude AI) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Square Payments ─────────────────────────────────────────────────────────
# Server-side (secret — never expose to browser)
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key

# Subscription plan catalog item IDs (create in Square Dashboard → Catalog)
SQUARE_PLAN_BASIC_ID=your_basic_plan_catalog_id
SQUARE_PLAN_PRO_ID=your_pro_plan_catalog_id
SQUARE_PLAN_PARTNER_ID=your_partner_plan_catalog_id

# Client-side (safe to expose — prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_SQUARE_APP_ID=your_square_app_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
# Change to "production" when going live

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Change to your live domain when deployed: https://expunge.ai
